#HTML file
<!DOCTYPE html>
<html>
<head>
    <title>Travel Destination Card</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="card">
        <img src="paris.jpg" alt="Paris">

        <h2>Paris</h2>

        <p>
            Paris is one of the most beautiful cities in the world. It is
            famous for the Eiffel Tower, delicious food, and amazing culture.
        </p>

        <button>Visit</button>
    </div>

</body>
</html>

#CSS file
body{
    background-color: #f8f4e8;
    font-family: Verdana, sans-serif;
}

.card{
    width: 320px;
    margin: 40px auto;
    padding: 18px;
    background-color: #fffdf8;
    border: 2px solid #c49a6c;
    border-radius: 12px;
    text-align: center;
}

.card::before{
    content: "Explore";
    color: #8b4513;
    font-size: 18px;
    font-weight: bold;
}

.card img{
    width: 100%;
    height: 210px;
    margin-top: 10px;
    border-radius: 8px;
}

.card h2{
    color: #5c4033;
}

.card p{
    color: #444;
    text-align: justify;
    font-size: 15px;
    padding: 8px;
}

button{
    background-color: #c49a6c;
    color: white;
    border: none;
    padding: 10px 18px;
    margin-top: 10px;
    border-radius: 6px;
}

button:hover{
    background-color: brown;
    color: white;
    cursor: pointer;
}

.card:hover{
    border-color: #8b4513;
}
